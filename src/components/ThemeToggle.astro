<!-- src/components/ThemeToggle.astro -->
<button id="theme-toggle" class="btn-toggle" aria-label="Alternar Tema">
  <span class="icon" id="theme-icon">☀️</span>
  <span class="label">TEMA</span>
</button>

<style>
  .btn-toggle {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 1000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    padding: 0.5rem;
    background-color: var(--bg-card);
    border: 2px solid var(--border-color);
    border-radius: 8px;
    color: var(--texto-principal);
    font-weight: bold;
    font-size: 0.7rem;
    cursor: pointer;
    box-shadow: var(--sombra-card);
    transition: transform 0.15s ease-in-out, background-color 0.4s ease, border-color 0.4s ease;
  }

  /* Efeito de clique físico do botão do console */
  .btn-toggle:active {
    transform: scale(0.92);
  }

  .btn-toggle:hover {
    border-color: var(--texto-secundario);
  }

  .icon {
    font-size: 1.2rem;
    margin-bottom: 1px;
  }

  .label {
    letter-spacing: 1px;
    font-weight: 800;
    color: var(--texto-secundario);
  }
</style>

<script>
  const setupTheme = () => {
    const toggle = document.getElementById('theme-toggle');
    const icon = document.getElementById('theme-icon');
    const html = document.documentElement;

    const applyTheme = (theme) => {
      const safeTheme = theme === 'light' || theme === 'dark' ? theme : 'dark';
      html.setAttribute('data-theme', safeTheme);
      localStorage.setItem('theme', safeTheme);

      if (icon) {
        icon.textContent = safeTheme === 'light' ? '🌙' : '☀️';
      }
    };

    const currentTheme = localStorage.getItem('theme') || 'dark';
    applyTheme(currentTheme);

    if (toggle && !toggle.dataset.bound) {
      toggle.addEventListener('click', () => {
        const isLight = html.getAttribute('data-theme') === 'light';
        applyTheme(isLight ? 'dark' : 'light');
      });
      toggle.dataset.bound = 'true';
    }
  };

  setupTheme();
  document.addEventListener('astro:after-swap', setupTheme);
</script>
