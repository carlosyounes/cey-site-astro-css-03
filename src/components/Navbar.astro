---
/* Painel de Controle do Astro para detecção automática de URLs */
const { pathname } = Astro.url;

const isActive = (path: string) => {
  if (path === '/' && pathname === '/') return 'active';
  if (path !== '/' && pathname.startsWith(path)) return 'active';
  return '';
};
---

<header class="navbar-header">
  <div class="navbar-container">
    
    <!-- LOGO -->
    <a href="./" class="logo">CEY MUSIC</a>

    <!-- NAVEGAÇÃO DE 8 BOTÕES FÍSICOS EM NEON -->
    <nav class="menu-neon">
      
      <a href="./" class={`item-neon ${isActive('/')}`} style="--cor: var(--neon-cyan)">
        <span class="btn-txt">Home</span>
        <div class="linha"></div>
      </a>

      <a href="./musica" class={`item-neon ${isActive('/musica')}`} style="--cor: var(--neon-magenta)">
        <span class="btn-txt">Música</span>
        <div class="linha"></div>
      </a>

      <a href="tecnologia" class={`item-neon ${isActive('/tecnologia')}`} style="--cor: var(--neon-green)">
        <span class="btn-txt">Tecnologia</span>
        <div class="linha"></div>
      </a>

      <a href="./produtos" class={`item-neon ${isActive('/produtos')}`} style="--cor: var(--neon-orange)">
        <span class="btn-txt">Produtos</span>
        <div class="linha"></div>
      </a>

      <a href="servicos" class={`item-neon ${isActive('/servicos')}`} style="--cor: var(--neon-cyan)">
        <span class="btn-txt">Serviços</span>
        <div class="linha"></div>
      </a>

      <a href="arte-educacao" class={`item-neon ${isActive('/arte-educacao')}`} style="--cor: var(--neon-magenta)">
        <span class="btn-txt">Arte/Educ</span>
        <div class="linha"></div>
      </a>

      <a href="artigos" class={`item-neon ${isActive('/artigos')}`} style="--cor: var(--neon-green)">
        <span class="btn-txt">Artigos</span>
        <div class="linha"></div>
      </a>

      <a href="contatos" class={`item-neon ${isActive('/contatos')}`} style="--cor: var(--neon-orange)">
        <span class="btn-txt">Contatos</span>
        <div class="linha"></div>
      </a>

    </nav>
  </div>
</header>

<style>
  .navbar-header {
    width: 100%;
    background-color: var(--bg-principal);
    border-bottom: 3px solid var(--border-color);
    position: sticky;
    top: 0;
    z-index: 900;
    transition: background-color 0.4s ease, border-color 0.4s ease;

    box-shadow: inset 0 3px 5px rgba(0, 0, 0, 0.5); /* Sombra interna simula que ele entrou no painel */
  
  }

  .navbar-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem;
    display: flex;
    flex-direction: column; /* Mobile first */
    gap: 1rem;
  }

  .logo {
    font-weight: 800;
    font-size: 1.7rem;
    color: var(--texto-principal);
    text-decoration: none;
    text-align: center;
    letter-spacing: 2px;
    align-self: flex-start;
    transition: color 0.4s ease;

    
  }

  /* GRADE MOBILE (4 COLUNAS) */
  .menu-neon {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.6rem; /* Ajustado para dar espaço para as bordas individuais dos botões */
    width: 100%;
  }

  /* AJUSTE: Transformado em um botão físico completo com contorno nos 4 lados */
  .item-neon {
    text-decoration: none;
    text-transform: uppercase; 
    cursor: pointer;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.6rem 0.4rem;
    background-color: var(--bg-card); /* Fundo sutil para parecer um botão em relevo */
    border: 1px solid var(--border-color); /* Contorno nos 4 lados */
    border-radius: 8px; /* Bordas arredondadas nos botões */
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 2px 4px rgba(0, 0, 0, 0.2); /* Volume leve de botão */
    outline: none;
    position: relative;
    /* Transição ultra rápida para a física de clique parecer mecânica e firme */
    transition: transform 0.1s ease, box-shadow 0.1s ease, border-color 0.3s ease, background-color 0.3s ease;
  }

  /* Comportamento de Hover: pré-ilumina levemente a borda do botão antes do clique */
  .item-neon:hover {
    border-color: var(--texto-secundario);
    transform: translateY(-1px); /* Pequeno balanço para cima */
  }

  /* AJUSTE MÁGICO: Sensação tátil de AFUNDAR fisicamente ao clicar */
  .item-neon:active {
    transform: translateY(2px); /* Desloca o botão para baixo simula o clique */
    box-shadow: inset 0 3px 5px rgba(0, 0, 0, 0.5); /* Sombra interna simula que ele entrou no painel */
  }

  .btn-txt {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--texto-secundario);
    transition: color 0.3s ease;
  }




  

  /* ==========================================================================
     ESTADO ATIVO: O BOTÃO TRAVADO ACESO NO PAINEL
     ========================================================================== */
  .item-neon.active {
    background-color: rgba(24, 24, 34, 0.4); /* Leve variação de fundo para botão pressionado */
    border-color: var(--cor); /* O contorno inteiro dos 4 lados acende na cor neon do canal! */
    box-shadow: 0 0 10px rgba(0, 243, 255, 0.1), inset 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  /* Acende o texto correspondente */
  .item-neon.active .btn-txt { 
    color: var(--cor); 
    text-shadow: 0 0 8px var(--cor);
  }
  
  /* Acende o pequeno LED indicador */
  .item-neon.active .linha {
    background-color: var(--cor);
    box-shadow: 0 0 10px var(--cor), 0 0 20px var(--cor);
  }

  /* COMPORTAMENTO DESKTOP (Telas Maiores) */




  
  @media (min-width: 768px) {
    .navbar-container {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }

    .menu-neon {
      display: flex;
      width: auto;
      gap: 1rem; /* Espaçamento elegante entre os blocos físicos */
    }

    .item-neon {
      padding: 0.6rem 1.2rem; /* Mais gordinho no desktop para simular teclas reais */
    }

    .btn-txt { font-size: 0.85rem; }
  }
</style>
