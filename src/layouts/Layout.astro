---
// 1. IMPORTAÇÃO DOS COMPONENTES E DO MOTOR DE CORES
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

// Importações locais das fontes para o Astro calcular as URLs corretas automaticamente no Deploy
import orbitronUrl from '../fonts/orbitron.woff2';
import plusJakartaUrl from '../fonts/plusjakarta-variable.woff2';
import jetbrainsMonoUrl from '../fonts/jetbrainsmono.woff2';

// Importa o roteador cliente nativo para gerenciar as View Transitions
import { ClientRouter } from 'astro:transitions';

const { title = "Meu Console Portfolio" } = Astro.props;
---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- ATIVAÇÃO DAS TRANSIÇÕES DO ASTRO -->
    <ClientRouter />

    <!-- PRE-CARREGAMENTO DINÂMICO DE FONTES (Utiliza as URLs geradas pelo Astro) -->
    <link rel="preload" href={orbitronUrl} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={plusJakartaUrl} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={jetbrainsMonoUrl} as="font" type="font/woff2" crossorigin="anonymous" />
    
    <!-- BARREIRA CRÍTICA CONTRA FLASH DE TEMA -->
    <script is:inline>
      (() => {
        const getTheme = () => {
          const saved = localStorage.getItem('theme');
          return saved === 'light' || saved === 'dark' ? saved : 'dark';
        };

        const applyTheme = () => {
          const theme = getTheme();
          document.documentElement.setAttribute('data-theme', theme);
          document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'dark';
        };

        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <!-- ESTILO CRÍTICO INLINE (Injeta as variáveis calculadas pelo Astro) -->
    <style is:inline define:vars={{ orbitronUrl, plusJakartaUrl, jetbrainsMonoUrl }}>
      @font-face {
        font-family: 'Orbitron';
        src: url(var(--orbitronUrl)) format('woff2');
        font-weight: 400 900;
        font-style: normal;
        font-display: block;
      }

      @font-face {
        font-family: 'Plus Jakarta';
        src: url(var(--plusJakartaUrl)) format('woff2');
        font-weight: 100 900;
        font-style: normal;
        font-display: block;
      }

      @font-face {
        font-family: 'JetBrains Mono';
        src: url(var(--jetbrainsMonoUrl)) format('woff2');
        font-weight: 100 800;
        font-style: normal;
        font-display: block;
      }

      html {
        scrollbar-gutter: stable !important;
        color-scheme: dark light;
        background-color: #0a0a0c;
      }

      body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        background-color: #0a0a0c;
        color: #f3f4f6;
        min-height: 100vh;
      }

      html[data-theme="light"] body {
        background-color: #e7c46e;
        color: #2b2416;
      }

      h1, h2, h3, .logo, .btn-txt {
        font-family: 'Orbitron', sans-serif !important;
      }

      body, p, li {
        font-family: 'Plus Jakarta', sans-serif !important;
      }

      code, pre, .lcd-display, .matrix-text {
        font-family: 'JetBrains Mono', monospace !important;
      }
    </style>
  </head>
  
  <body>
    <Navbar />

    <!-- O miolo do site animado em fade de 0.4s pelo seu global.css -->
    <main transition:animate="fade">
      <slot />
    </main>

    <ThemeToggle />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
</style>
