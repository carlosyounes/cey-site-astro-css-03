<!-- Script de Bloqueio de Flicker (Injeta o tema creme antes do HTML desenhar) -->
   <!-- <script is:inline>
      function aplicarTemaDefinitivo() {
        const temaSalvo = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', temaSalvo);
      }

      // Executa no primeiro carregamento
      aplicarTemaDefinitivo();

      // Executa instantaneamente na troca de cada uma das 9 páginas
      document.addEventListener('astro:after-swap', aplicarTemaDefinitivo);
    </script>   -->



  <script is:inline>
    (() => {
      const getTheme = () => {
        const saved = localStorage.getItem('theme');
        return saved === 'light' || saved === 'dark' ? saved : 'dark';
      };

      const applyTheme = () => {
        const theme = getTheme();
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.style.colorScheme = theme === 'light' ? 'light' : 'dark';
      };

      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    })();
  </script>





    <!-- ESTILO CRÍTICO INLINE -->
    <style is:inline>
      @font-face {
        font-family: 'Orbitron';
        src: url('/src/fonts/orbitron.woff2') format('woff2');
        font-weight: 400 900;
        font-style: normal;
        font-display: block;
      }

      @font-face {
        font-family: 'Plus Jakarta';
        src: url('/src/fonts/plusjakarta-variable.woff2') format('woff2');
        font-weight: 100 900;
        font-style: normal;
        font-display: block;
      }

      @font-face {
        font-family: 'JetBrains Mono';
        src: url('/src/fonts/jetbrainsmono.woff2') format('woff2');
        font-weight: 100 800;
        font-style: normal;
        font-display: block;
      }

      html {
        scrollbar-gutter: stable !important;
        color-scheme: dark light;
        background-color: #0a0a0c;
      }

      body {
        margin: 0;
        padding: 0;
        overflow-x: hidden;
        background-color: #0a0a0c;
        color: #f3f4f6;
        min-height: 100vh;
      }

      html[data-theme="light"] body {
        background-color: #e7c46e;
        color: #2b2416;
      }

      h1, h2, h3, .logo, .btn-txt {
        font-family: 'Orbitron', sans-serif !important;
      }

      body, p, li {
        font-family: 'Plus Jakarta', sans-serif !important;
      }

      code, pre, .lcd-display, .matrix-text {
        font-family: 'JetBrains Mono', monospace !important;
      }
    </style>
  </head>
  
  <body>
    <Navbar />

    <!-- O miolo do site animado em fade de 0.4s pelo seu global.css -->
    <main transition:animate="fade">
      <slot />
    </main>

    <ThemeToggle />
  </body>
</html>

<style>
  main {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }
</style>
