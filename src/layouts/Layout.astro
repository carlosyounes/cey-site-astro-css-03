---
// 1. IMPORTAÇÃO DOS COMPONENTES E DO MOTOR DE CORES

import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

// Importa o roteador cliente nativo para gerenciar as View Transitions
import { ClientRouter } from 'astro:transitions';

const { title = "Meu Console Portfolio" } = Astro.props;
---






<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- ATIVAÇÃO DAS TRANSIÇÕES DO ASTRO -->
    <ClientRouter />

    <!-- PRE-CARREGAMENTO AGRESSIVO DE FONTES -->
    <link rel="preload" href="/cey-site-astro-css-03/src/fonts/orbitron.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/cey-site-astro-css-03/src/fonts/plusjakarta-variable.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href="/cey-site-astro-css-03/src/fonts/jetbrainsmono.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
    
    <!-- BARREIRA CRÍTICA CONTRA FLASH DE TEMA (Executa na carga inicial da aba) -->
   <!-- <script is:inline>
      // Função rápida para injetar o tema correto na tag <html>
