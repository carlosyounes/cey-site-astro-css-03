---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Canal - Tecnologia | Meu Console Portfolio">
  <section class="card-volume text-panel">
    <h1>CANAL: TECNOLOGIA</h1>
    <p class="matrix-text">Status do Canal: Conectado e Operando.</p>
    <p>Este é o conteúdo temporário do painel de tecnologia. Modifique este arquivo em src/pages/tecnologia.astro para inserir seus cards e publicações reais.</p>
  </section>
</Layout>

<style>
  .text-panel {
    padding: 3rem 2rem;
    margin-top: 2rem;
  }
  h1 {
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }
  .matrix-text {
    color: var(--neon-cyan);
    font-weight: bold;
    margin-bottom: 1.5rem;
  }
</style>
